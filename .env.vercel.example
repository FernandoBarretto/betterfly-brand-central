# ── Vercel Frontend ──────────────────────────────────────────────────
# Railway API URL (the public URL of your Railway deployment)
# Used in vercel.json rewrites to proxy /api/* requests
RAILWAY_API_URL=https://your-app.up.railway.app

# Vite env var for local dev proxy target (optional, default http://localhost:5000)
# VITE_API_URL=http://localhost:5000
