{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm run build:client",
  "outputDirectory": "dist/public",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://web-production-b1ac3a.up.railway.app/api/:path*"
    },
    {
      "source": "/brand-assets/:path*",
      "destination": "https://web-production-b1ac3a.up.railway.app/brand-assets/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
